# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
# Comma-separated list, or '*' to allow all (avoid '*' in production)
CORS_ORIGIN=http://localhost:5173

# Firebase Admin (optional until auth is implemented)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cloudinary (optional until uploads are implemented)
# Prefer CLOUDINARY_URL, otherwise set the 3 vars below.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# If you use Google Application Default Credentials instead:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json
